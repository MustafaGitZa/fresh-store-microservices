<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_09b3p76" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.45.0" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:process id="order-fulfillment"
                name="Order Fulfillment"
                isExecutable="true"
                camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_1" name="Order Received">
      <bpmn:outgoing>Flow_1c0ty9d</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Activity_1mtj5py" name="Process Payment" camunda:delegateExpression="${processPaymentDelegate}">
      <bpmn:incoming>Flow_1c0ty9d</bpmn:incoming>
      <bpmn:outgoing>Flow_12b3axy</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1c0ty9d" sourceRef="StartEvent_1" targetRef="Activity_1mtj5py" />
    <bpmn:serviceTask id="Activity_009ealg" name="Update Inventory" camunda:delegateExpression="${updateInventoryDelegate}">
      <bpmn:incoming>Flow_1fe9kn4</bpmn:incoming>
      <bpmn:outgoing>Flow_05xoj60</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_0l8wdo1" name="Payment Result?">
      <bpmn:incoming>Flow_12b3axy</bpmn:incoming>
      <bpmn:outgoing>Flow_1fe9kn4</bpmn:outgoing>
      <bpmn:outgoing>Flow_0poo49l</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sequenceFlow id="Flow_12b3axy" sourceRef="Activity_1mtj5py" targetRef="Gateway_0l8wdo1" />
    <bpmn:sequenceFlow id="Flow_1fe9kn4" sourceRef="Gateway_0l8wdo1" targetRef="Activity_009ealg">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${paymentStatus == 'APPROVED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:endEvent id="Event_1878v8a" name="Order Declined">
      <bpmn:incoming>Flow_0poo49l</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_0poo49l" sourceRef="Gateway_0l8wdo1" targetRef="Event_1878v8a">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${paymentStatus == 'DECLINED'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Activity_1qi5wax" name="Confirm Delivery" camunda:delegateExpression="${confirmDeliveryDelegate}">
      <bpmn:incoming>Flow_05xoj60</bpmn:incoming>
      <bpmn:outgoing>Flow_04e4yom</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_05xoj60" sourceRef="Activity_009ealg" targetRef="Activity_1qi5wax" />
    <bpmn:endEvent id="Event_0o1myqd" name="Order Completed">
      <bpmn:incoming>Flow_04e4yom</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_04e4yom" sourceRef="Activity_1qi5wax" targetRef="Event_0o1myqd" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
